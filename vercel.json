{
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/haori", "destination": "/haori.html" },
    { "source": "/kimono", "destination": "/kimono.html" },
    { "source": "/styling", "destination": "/styling.html" },
    { "source": "/voucher", "destination": "/voucher.html" },
    { "source": "/size-chart", "destination": "/size-chart.html" },
    { "source": "/care", "destination": "/care.html" },
    { "source": "/returns", "destination": "/returns.html" },
    { "source": "/contact", "destination": "/contact.html" },
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/cookies", "destination": "/cookies.html" },
    { "source": "/checkout", "destination": "/checkout.html" },
    { "source": "/success", "destination": "/success.html" },
    { "source": "/admin", "destination": "/admin.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ]
}
